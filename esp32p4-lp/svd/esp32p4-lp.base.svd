            <field>
              <name>TEE_REG_HP_CORE1_MM_REGION_2_TO_7_PMS</name>
              <description>NA</description>
              <bitOffset>24</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>TEE_PERI_REGION2_LOW</name>
          <addressOffset>0x24</addressOffset>
          <description>NA</description>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEE_REG_PERI_REGION2_LOW</name>
              <description>NA</description>
              <bitOffset>2</bitOffset>
              <bitWidth>30</bitWidth>
              <access>read-write</access>
            </field>
