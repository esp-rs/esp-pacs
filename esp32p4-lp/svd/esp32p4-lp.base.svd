        </register>
        <register>
          <name>TEE_PERI_REGION5_HIGH</name>
          <addressOffset>0x40</addressOffset>
          <description>NA</description>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEE_REG_PERI_REGION5_HIGH</name>
              <description>NA</description>
              <bitOffset>2</bitOffset>
              <bitWidth>30</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>TEE_PERI_REGION6_LOW</name>
          <addressOffset>0x44</addressOffset>
          <description>NA</description>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>TEE_REG_PERI_REGION6_LOW</name>
              <description>NA</description>
              <bitOffset>2</bitOffset>
              <bitWidth>30</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>TEE_PERI_REGION6_HIGH</name>
          <addressOffset>0x48</addressOffset>
          <description>NA</description>
