          <size>32</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LP_I2C_SDA_HOLD_TIME</name>
              <description>This register is used to configure the time to hold the data after the negativeedge of SCL, in I2C module clock cycles.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>9</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>LP_I2C_SDA_SAMPLE</name>
          <addressOffset>0x34</addressOffset>
          <description>Configures the sample time after a positive SCL edge.</description>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>LP_I2C_SDA_SAMPLE_TIME</name>
