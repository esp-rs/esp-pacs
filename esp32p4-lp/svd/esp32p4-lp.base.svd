            <field>
              <name>TEE_REG_HP_CORE0_MM_REGION_2_TO_7_PMS</name>
              <description>NA</description>
              <bitOffset>12</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEE_REG_HP_CORE1_UM_REGION_2_TO_7_PMS</name>
              <description>NA</description>
              <bitOffset>18</bitOffset>
              <bitWidth>6</bitWidth>
              <access>read-write</access>
