    <peripheral>
      <name>LP_TRNG</name>
      <description>LP_TRNG</description>
      <groupName>LP_TRNG</groupName>
      <baseAddress>0x50126000</baseAddress>
      <interrupt>
        <name>LP_TRNG</name>
        <description>LP TRNG interrupt</description>
        <value>15</value>
      </interrupt>
      <addressBlock>
        <offset>0</offset>
        <size>0x00000080</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>RNG_CFG</name>
          <addressOffset>0x0</addressOffset>
          <description>configure rng register</description>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>RNG_SAMPLE_ENABLE</name>
              <description>enable rng RO 1: enable RO 0: disable RO</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>RNG_TIMER_PSCALE</name>
              <description>configure rng timer clk div</description>
              <bitOffset>1</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>RNG_TIMER_EN</name>
              <description>enable rng xor async rng timer</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>RNG_SAMPLE_CNT</name>
              <description>get rng RO sample cnt</description>
              <bitOffset>24</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>RNG_DATA</name>
          <addressOffset>0x4</addressOffset>
          <description>RNG result register</description>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>RNG_DATA</name>
              <description>get rng data</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>RNG_RSTN</name>
          <addressOffset>0x8</addressOffset>
          <description>rng rstn register</description>
          <size>32</size>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>RNG_RSTN</name>
              <description>enable rng system reset: 1: not reset, 0: reset</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>RNG_DATE</name>
          <addressOffset>0xc</addressOffset>
