[13] 1'b1: po_cnnt_rstn bypass hp_cpu_intrusion_rstn
[12] 1'b1: po_cnnt_rstn bypass hp_sdio_sys_rstn
[11] 1'b1: po_cnnt_rstn bypass usb_jtag_chip_rst
[10] 1'b1: po_cnnt_rstn bypass usb_uart_chip_rst
