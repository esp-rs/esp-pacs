              <access>read-write</access>
            </field>
            <field>
              <name>TEE_REG_HP_CORE1_MM_REGION_PMS</name>
              <description>NA</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>TEE_PERI_REGION_2_TO_7_PMS</name>
          <addressOffset>0x20</addressOffset>
          <description>NA</description>
          <size>32</size>
